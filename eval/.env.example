# ── Провайдер судьи ───────────────────────────────────────────────────────────
# Доступные значения: openai | openrouter | gigachat
JUDGE_PROVIDER=openrouter

# ── Модель судьи ──────────────────────────────────────────────────────────────
# OpenRouter:  qwen/qwen-2.5-72b-instruct | qwen/qwen3-235b-a22b
#              openai/gpt-4o-mini | openai/gpt-4o
#              google/gemini-flash-1.5
# OpenAI:      gpt-4o-mini | gpt-4o
# GigaChat:    GigaChat-Pro | GigaChat-Max
JUDGE_MODEL=qwen/qwen-2.5-72b-instruct

# ── API-ключи ─────────────────────────────────────────────────────────────────

# OpenRouter (рекомендуется — доступ к любой модели)
OPENROUTER_API_KEY=

# OpenAI (если JUDGE_PROVIDER=openai)
OPENAI_API_KEY=

# GigaChat (Client Secret из developers.sber.ru)
GIGACHAT_CREDENTIALS=

# ── RAG API (для онлайн-режима и pytest) ──────────────────────────────────────
# RAG_API_BASE_URL=https://your-api.example.com
