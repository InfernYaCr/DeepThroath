# ── Target model ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Для Claude-моделей напрямую

OPENROUTER_API_KEY=sk-or-v1-...    # Для любой модели через OpenRouter
                                    # Получить: https://openrouter.ai/keys

# ── Judge (LLM-as-a-Judge) — выберите один вариант ────────────
#
# Вариант 1: GPT-4o-mini (дёшево, хорошее качество)
OPENAI_API_KEY=sk-...
# → judge_preset: gpt-4o-mini  в config/attack_config.yaml
#
# Вариант 2: Gemini Flash через OpenRouter (самый дешёвый)
# OPENROUTER_API_KEY уже задан выше
# → judge_preset: gemini-flash
#
# Вариант 3: Claude Haiku (Anthropic, быстрый)
# ANTHROPIC_API_KEY уже задан выше
# → judge_preset: haiku
#
# Вариант 4: Llama 3.3 70B через OpenRouter (открытая модель)
# OPENROUTER_API_KEY уже задан выше
# → judge_preset: llama3-70b
#
# Вариант 5: Ollama локально (БЕСПЛАТНО)
# brew install ollama && ollama pull llama3.2 && ollama serve
# → judge_preset: ollama-llama  (не нужен API-ключ)

# ── Настройки сканирования ─────────────────────────────────────
ASR_THRESHOLD=0.20                  # CI падает если ASR > 20%
RESULTS_DIR=./results
